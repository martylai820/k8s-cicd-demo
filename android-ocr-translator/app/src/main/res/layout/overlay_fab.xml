<?xml version="1.0" encoding="utf-8"?>
<!--
  Floating action button shown on top of all other apps.
  Tapping it triggers a screen capture + translation.
  Dragging repositions it anywhere on screen.
-->
<com.google.android.material.floatingactionbutton.FloatingActionButton
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fabCapture"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:src="@drawable/ic_translate"
    android:contentDescription="@string/fab_capture_description"
    app:backgroundTint="?attr/colorPrimary"
    app:tint="@android:color/white"
    app:fabSize="normal"
    app:elevation="8dp"
    app:pressedTranslationZ="12dp"
    app:rippleColor="@android:color/white" />
